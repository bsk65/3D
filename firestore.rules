rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth.uid == uid;
      match /{subcol}/{docId} {
        allow read, write: if request.auth.uid == uid;
        match /{sub2}/{doc2} {
          allow read, write: if request.auth.uid == uid;
        }
      }
      // Tillad en medskytte at "levere" en fælles runde ind i denne brugers
      // rounds-samling, men kun som ny runde (create) og kun hvis medskytten
      // OG målbrugeren (uid) begge står opført som skytte i selve runde-dataen.
      match /rounds/{roundId} {
        allow create: if request.auth != null &&
          request.auth.uid != uid &&
          request.resource.data.shooterIds is list &&
          request.auth.uid in request.resource.data.shooterIds &&
          uid in request.resource.data.shooterIds;
      }
    }
    match /courses/{courseId} {
      allow read: if request.auth != null &&
        (resource.data.hidden != true
         || exists(/databases/$(database)/documents/admins/$(request.auth.uid))
         || (request.auth.token.email != null && resource.data.approvedUsers.hasAny([request.auth.token.email.lower()])));
      allow write: if exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }
    match /admins/{uid} {
      allow read: if request.auth != null;
      // Kun den ene hardkodede super-admin må styre admin-listen (matcher
      // state.isSuperAdmin-tjekket i js/app-init.js). Uden dette kunne enhver
      // almindelig admin udnævne/fjerne andre admins, inkl. super-adminen selv.
      allow write: if request.auth.token.email == 'bsklausen@proton.me';
    }
    match /meetups/{meetupId} {
      // "Skal vi skyde sammen": opretteren inviterer altid eksplicit
      // (invitedUids) — der findes ingen "helt åben, ingen invitation"-tilstand.
      allow read: if request.auth != null &&
        (resource.data.creatorUid == request.auth.uid ||
         request.auth.uid in resource.data.invitedUids ||
         request.auth.token.email == 'bsklausen@proton.me');
      allow create: if request.auth != null &&
        request.resource.data.creatorUid == request.auth.uid &&
        request.resource.data.invitedUids is list &&
        request.resource.data.status == 'åben';
      allow update: if request.auth != null &&
        (resource.data.creatorUid == request.auth.uid ||
         request.auth.uid in resource.data.invitedUids) &&
        request.resource.data.creatorUid == resource.data.creatorUid &&
        request.resource.data.invitedUids == resource.data.invitedUids;
      // Aftaler slettes aldrig af klienten — de forsvinder automatisk via
      // Firestore TTL-policy på expireAt-feltet (sættes op separat i Firebase Console).
      allow delete: if false;
    }
    match /bane_stats/{courseId}/runder/{roundId} {
      allow read: if request.auth != null &&
        (!exists(/databases/$(database)/documents/courses/$(courseId))
         || get(/databases/$(database)/documents/courses/$(courseId)).data.hidden != true
         || exists(/databases/$(database)/documents/admins/$(request.auth.uid))
         || (request.auth.token.email != null && get(/databases/$(database)/documents/courses/$(courseId)).data.approvedUsers.hasAny([request.auth.token.email.lower()])));
      // Dokumenterne er anonyme (intet ejer-felt), og roundId er et forudsigeligt
      // Date.now()-baseret ID — derfor må write ikke tillade vilkårlig
      // overskrivning/sletning. create er stadig åben (crowd-sourced anonym
      // statistik); delete kræver at brugeren selv har rundens ID i sin egen
      // rounds-samling (proxy for ejerskab, jf. results.js' egen-runde-sletning).
      allow create: if request.auth != null;
      allow update: if false;
      allow delete: if request.auth != null &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)/rounds/$(roundId));
    }
  }
}
